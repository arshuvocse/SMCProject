   table.AddToListCssTable {
            /*border: 2px solid #1C6EA4;*/
            border-style: none;
            background-color: #FFFFFF;
            width: 100%;
            text-align: left;
            border-collapse: collapse;
        }
        table.AddToListCssTable td, table.AddToListCssTable th {
            /*border: 1px solid #AAAAAA;*/
            border-style: none;

            padding: 3px 2px;
        }
        table.AddToListCssTable tbody td {
            font-size: 13px;
            padding: 6px;
            text-align: left;
        }
        table.AddToListCssTable tr:nth-child(even) {
            background: #DCF5EB;
        }
        table.AddToListCssTable thead {
            background: #1C6EA4;
            background: -moz-linear-gradient(top, #5592bb 0%, #327cad 66%, #1C6EA4 100%);
            background: -webkit-linear-gradient(top, #5592bb 0%, #327cad 66%, #1C6EA4 100%);
            background: linear-gradient(to bottom, #5592bb 0%, #327cad 66%, #1C6EA4 100%);
        }
        table.AddToListCssTable thead th {
            font-size: 13px;
            height: 25px;
            font-weight: bold;
            color: #FFFFFF;
            text-align: left;
            /*border-left: 2px solid #D0E4F5;*/
