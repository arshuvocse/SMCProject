<body style="position: absolute;">
    <form id="form1" runat="server">
        <asp:ScriptManager ID="ScriptManager1"     AsyncPostBackTimeout="9999" runat="server">
        </asp:ScriptManager>
        <script language="javascript">
            function show() {
                document.write("<head runat='server'></head>");
            }
        </script>
        <div class="page page--w-header  page--w-fixed-header">
            <%--        page--w-fixed-header--%>
            <header class="page__header">
                <div class="logo-holder">
                    <a href="../DashBoard_UI/DashBoard.aspx" class="logo-text d-none d-lg-block">

                        <img src="../Assets/LogoForLeftCorner.jpg" height="32" width="80" />
                        <strong class="text-primary"></strong><strong>HRIS</strong>
                    </a><a href="../DashBoard_UI/DashBoard.aspx" class="logo-text d-lg-none"><strong class="text-primary">#</strong><strong>HRIS</strong></a>

                    <div class="rw-btn rw-btn--nav" data-action="aside-hide"><span></span></div>
                </div>

            </header>
             
            <div class="page__content page__content--w-aside-fixed" id="page-content" style="background-color: #F5F5F5">
                
                <div class="page-aside invert" id="page-aside" style="background-color: #222C32;">
                    <div class="scroll" style="max-height: 100%">
                       
                        <div class="navigation" style="background-color: #222C32;">
                            <div class="user user--bordered user--lg user--w-lineunder user--controls">
                                <img src="../Assets/man-icon.png"><div class="user__name">
                                    <strong>
                                        <label>
                                            Welcome
                                        </label>
                                        <br />
                                        <asp:Label runat="server" ID="lblUserName" Font-Size="15px" font-style="italic"></asp:Label>
                                    </strong>
                                    <br>
                                    <span class="text-muted">
                                        <asp:Label runat="server" ID="lblUserDes" Font-Size="12px"></asp:Label></span><div class="user__controls">
                                            <div class="dropdown">
                                                <button class="btn btn-light btn-sm btn-icon" data-toggle="dropdown" aria-haspopup="true" aria-expanded="false"><span class="fa fa-cog"></span></button>
                                                <div class="dropdown-menu dropdown-menu-right" aria-labelledby="dropdownMenuButton">
                                                    <a class="dropdown-item" style="text-align: left;" href="../UserProfile/UserProfile.aspx">Profile</a>
                                                    
                                                     <a class="dropdown-item" style="text-align: left;" href="../UserProfile/ChangePassword.aspx">Change Password</a>
                                                    <div class="dropdown-divider"></div>
                                                    <a class="dropdown-item" style="text-align: left;" href="../Default.aspx">Log out</a>
                                                </div>
                                            </div>
                                        </div>
                                </div>
                                <div class="user__lineunder">
                                    <div class="text">
                                        <asp:Label ID="lblLoginTime" runat="server" Font-Size="10px"></asp:Label></div>
                                    <div class="buttons">
                                        <div class="dropdown">
                                            <button class="button button-settings" data-toggle="dropdown" aria-haspopup="true" aria-expanded="false"></button>
                                            <div class="dropdown-menu" aria-labelledby="dropdownMenuButton" style="text-align: left;">
                                                <a class="dropdown-item" href="#">Profile</a>
                                                <div class="dropdown-divider"></div>
                                                <a class="dropdown-item" href="../Default.aspx">Log out</a>
                                            </div>
                                        </div>
                                        <%--<div class="button button-minimize" data-action="aside-minimize" data-toggle="tooltip" data-placement="top" data-original-title="Minimize navigation"></div>--%>
                                    </div>
                                </div>
                            </div>
                        </div>
                        
                                
                        <div class="navigation" id="navigation_default" style="background-color: #222C32; margin-top: -25px" runat="server">
                        </div>
                          
                    </div>
                </div>
                                <asp:HiddenField runat="server" ID="hfSesUserID"/>
                <asp:HiddenField runat="server" ID="hfForcePassChange" ClientIDMode="Static"/>
                <asp:ContentPlaceHolder ID="cpFormBody" runat="server">
                </asp:ContentPlaceHolder>
            </div>
        </div>
        <div class="modal fade" id="forcePasswordChangeModal" tabindex="-1" role="dialog" aria-labelledby="forcePasswordChangeTitle" aria-hidden="true" data-backdrop="static" data-keyboard="false">
            <div class="modal-dialog modal-dialog-centered" role="document">
                <div class="modal-content force-password-modal">
                    <div class="force-password-header">
                        <h5 class="modal-title" id="forcePasswordChangeTitle">
                            <span class="fa fa-lock"></span>
                            Password Change Required
                        </h5>
                    </div>
                    <div class="force-password-body">
                        <div class="force-password-icon">
                            <span class="fa fa-shield"></span>
                        </div>
                        <h4>Please update your password</h4>
                        <p>Your account requires a password update before continuing. This window cannot be closed until the password is changed.</p>
                        <a class="force-password-action" href="../UserProfile/ChangePassword.aspx">
                            <span class="fa fa-refresh"></span>
                            Change Password Now
                        </a>
                    </div>
                </div>
            </div>
        </div>
        <style>
            #forcePasswordChangeModal .modal-dialog {
                max-width: 500px;
            }

            #forcePasswordChangeModal .force-password-modal {
                overflow: hidden;
                border: 0;
                border-radius: 8px;
                background: #f8fbff;
                box-shadow: 0 24px 70px rgba(15, 23, 42, .34);
            }

            #forcePasswordChangeModal .force-password-header {
                position: relative;
                overflow: hidden;
                padding: 24px 24px 25px;
                color: #263238;
                background: linear-gradient(135deg, #0f7f7c 0%, #078ac4 50%, #4b46e8 100%);
            }

            #forcePasswordChangeModal .force-password-header::after {
                position: absolute;
                inset: 1px 1px auto;
                height: 52%;
                content: "";
                background: linear-gradient(180deg, rgba(255, 255, 255, .22), rgba(255, 255, 255, 0));
                pointer-events: none;
            }

            #forcePasswordChangeModal .force-password-header .modal-title {
                position: relative;
                z-index: 1;
                display: flex;
                align-items: center;
                gap: 12px;
                margin: 0;
                color: #263238;
                font-size: 20px;
                font-weight: 800;
                line-height: 1.25;
                letter-spacing: 0;
            }

            #forcePasswordChangeModal .force-password-header .fa {
                font-size: 15px;
            }

            #forcePasswordChangeModal .force-password-body {
                padding: 27px 25px 26px;
                text-align: center;
                background:
                    radial-gradient(circle at top, rgba(16, 185, 129, .12), transparent 34%),
                    linear-gradient(180deg, #f8fbff 0%, #eef7ff 100%);
            }

            #forcePasswordChangeModal .force-password-icon {
                display: flex;
                align-items: center;
                justify-content: center;
                width: 58px;
                height: 58px;
                margin: 0 auto 15px;
                border-radius: 50%;
                background: linear-gradient(180deg, #ecfff7 0%, #d9fff0 100%);
                color: #0f7f7c;
                font-size: 25px;
                box-shadow: 0 12px 24px rgba(15, 127, 124, .16), inset 0 1px 0 rgba(255, 255, 255, .86);
            }

            #forcePasswordChangeModal .force-password-body h4 {
                margin: 0 0 8px;
                color: #17212b;
                font-size: 21px;
                font-weight: 800;
                line-height: 1.25;
                letter-spacing: 0;
            }

            #forcePasswordChangeModal .force-password-body p {
                max-width: 440px;
                margin: 0 auto 18px;
                color: #334155;
                font-size: 14px;
                line-height: 1.55;
            }

            #forcePasswordChangeModal .force-password-action {
                position: relative;
                overflow: hidden;
                display: flex;
                align-items: center;
                justify-content: center;
                gap: 9px;
                min-height: 44px;
                width: 100%;
                border-radius: 8px;
                color: #ffffff !important;
                background: linear-gradient(135deg, #0f7f7c 0%, #0988c7 52%, #4b46e8 100%);
                font-size: 16px;
                font-weight: 800;
                text-decoration: none !important;
                box-shadow: 0 14px 28px rgba(9, 136, 199, .26);
                transition: transform .18s ease, box-shadow .18s ease;
            }

            #forcePasswordChangeModal .force-password-action::after {
                position: absolute;
                inset: 1px 1px auto;
                height: 44%;
                content: "";
                border-radius: 8px 8px 18px 18px;
                background: linear-gradient(180deg, rgba(255, 255, 255, .28), rgba(255, 255, 255, 0));
                pointer-events: none;
            }

            #forcePasswordChangeModal .force-password-action:hover,
            #forcePasswordChangeModal .force-password-action:focus {
                transform: translateY(-1px);
                box-shadow: 0 18px 34px rgba(9, 136, 199, .32);
            }

            #forcePasswordChangeModal .force-password-action .fa {
                font-size: 17px;
            }

            @media (max-width: 575.98px) {
                #forcePasswordChangeModal .modal-dialog {
                    margin: 10px;
                }

                #forcePasswordChangeModal .force-password-header {
                    padding: 21px 22px;
                }

                #forcePasswordChangeModal .force-password-header .modal-title {
                    font-size: 18px;
                }

                #forcePasswordChangeModal .force-password-body {
                    padding: 25px 24px 26px;
                }
            }
            

            .mCSB_dragger_bar {
                width: 12px !important;
                color: #003A5E !important;
                background-color: #003A5E !important;
            }
            .GridPager a,
            .GridPager span {
                display: inline-block;
                padding: 3px 14px;
                margin-right: 8px;
                border-radius: 3px;
                height: 20px;
                border: solid 1px #c0c0c0;
                background: #e9e9e9;
                box-shadow: inset 0px 1px 0px rgba(255,255,255, .8), 0px 1px 3px rgba(0,0,0, .1);
                font-size: 14px;
                font-weight: bold;
                text-decoration: none;
                color: #717171;
                text-shadow: 0px 1px 0px rgba(255,255,255, 1);
            }

            .GridPager a {
                background-color: #f5f5f5;
                color: #969696;
                border: 1px solid #969696;
            }

            .GridPager span {
                background: #616161;
                box-shadow: inset 0px 0px 8px rgba(0,0,0, .5), 0px 1px 0px rgba(255,255,255, .8);
                color: #f0f0f0;
                text-shadow: 0px 0px 3px rgba(0,0,0, .5);
                border: 1px solid #3AC0F2;
            }


            .invert .navigation>ul>li.open>a {
                background: rgba(0,0,0,.6)!important;
                color: #ebebf5!important;
            }

            .invert .navigation>ul>li ul>li>a {
                background: rgba(0,0,0,.4)!important;
                color: #ebebf5!important;
            }
            
            .invert .navigation>ul>li ul>li>ul>li>a {
                background: rgba(0,0,0,.2)!important;
                color: #ebebf5!important;
            }
          
        </style>

