        <script type="text/javascript">
            $(document).ready(function () {
                var forcePasswordChange = $('#hfForcePassChange').val() === '1';
                var isChangePasswordPage = window.location.pathname.toLowerCase().indexOf('/userprofile/changepassword.aspx') !== -1;

                if (forcePasswordChange && !isChangePasswordPage) {
                    $('#forcePasswordChangeModal').modal({
                        backdrop: 'static',
                        keyboard: false,
                        show: true
                    });
                }
            });
        </script>
