    public string Parameter()
    {
        string param = "";
        if (itemGroupDropDownList.SelectedIndex >0)
        {
            param = param + " AND tblItemGroup.ItemGroupId='"+itemGroupDropDownList.SelectedValue+"'";
        }
        if (itemTypeDropDownList.SelectedIndex > 0)
        {
            param = param + " AND tblItemType.ItemTypeId='" + itemTypeDropDownList.SelectedValue + "'";
        }
        if (itemCatagoryDropDownList.SelectedIndex > 0)
        {
            param = param + " AND tblItemCategory.ItemCategoryId='" + itemCatagoryDropDownList.SelectedValue + "'";
        }
        if (itemNameDropDownList.SelectedIndex > 0)
        {
            param = param + " AND tblItemName.ItemNameId='" + itemNameDropDownList.SelectedValue + "'";
        }
        if (itemDescDropDownList.SelectedIndex > 0)
        {
            param = param + " AND tblItemDescription.ItemDescriptionId='" + itemDescDropDownList.SelectedValue + "'";
        }
        if (reportDropDownList1.SelectedValue == "ID")
        {
            if (itembrandDropDownList.SelectedIndex>0)
            {
                param = param + " AND tblItemBrand.BrandId='" + itembrandDropDownList.SelectedValue + "'";
            }
            if (itemSizeDropDownList.SelectedIndex > 0)
            {
                param = param + " AND tblItemSizeDetail.SizeDetailId='" + itemSizeDropDownList.SelectedValue + "'";
            }
            if (itemcolorDropDownList.SelectedIndex > 0)
            {
                param = param + " AND tblItemColour.ColourId='" + itemcolorDropDownList.SelectedValue + "'";
            }
            if (itemManufactureDropDownList.SelectedIndex > 0)
            {
                param = param + " AND tblItemManufacturer.ManufacturerId='" + itemManufactureDropDownList.SelectedValue + "'";
            }
            if (stockUnitDropDownList.SelectedIndex > 0)
            {
                param = param + " AND StockUnitId='" + stockUnitDropDownList.SelectedValue + "'";
            }
            if (defaultUnitDropDownList.SelectedIndex > 0)
            {
                param = param + " AND DefaultUnitId='" + defaultUnitDropDownList.SelectedValue + "'";
            }
        }
        return param;
    }
    protected void submitButton_Click(object sender, EventArgs e)
    {
        Session["ReportParameter"] = "";
        if (reportDropDownList1.SelectedValue=="IG")
        {
            Session["ReportParameter"] = "";
            PopUp();
        }
        if (reportDropDownList1.SelectedValue == "IT")
        {
            Session["ReportParameter"] = "";
        }
        if (reportDropDownList1.SelectedValue == "ICA")
        {
            Session["ReportParameter"] = "";
        }
        if (reportDropDownList1.SelectedValue == "IN")
        {
            Session["ReportParameter"] = "";

        }
        if (reportDropDownList1.SelectedValue == "ID")
        {
            Session["ReportParameter"] = "";

        }
        if (reportDropDownList1.SelectedValue == "IB")
        {
            Session["ReportParameter"] = "";

        }
        if (reportDropDownList1.SelectedValue == "IC")
        {
            Session["ReportParameter"] = "";

        }
        if (reportDropDownList1.SelectedValue == "IM")
        {
            Session["ReportParameter"] = "";

        }
        if (reportDropDownList1.SelectedValue == "IS")
        {
            Session["ReportParameter"] = "";

        }
        if (reportDropDownList1.SelectedValue == "UOM")
        {
            Session["ReportParameter"] = "";

        }
        if (reportDropDownList1.SelectedValue == "IP")
        {
            Session["ReportParameter"] = "";

        }
        PopUp();
    }

    private void PopUp()
    {
        string url = "../Report_UI/ItemInformationReportViewer.aspx?rptType=" + reportDropDownList1.SelectedValue;
        string fullURL = "window.open('" + url + "', '_blank', 'height=600,width=900,status=yes,toolbar=no,menubar=no,location=no,scrollbars=yes,resizable=no,titlebar=no' );";
        ScriptManager.RegisterStartupScript(this, typeof(string), "OPEN_WINDOW", fullURL, true);
    }
    protected void SearchButton_Click(object sender, EventArgs e)
    {
        if (itemsGridView.Columns.Count > 0)
        {
            itemsGridView.Columns.Clear();
        }
        //DivGroup.Visible = false;
        //divcat.Visible = false;
        //divname.Visible = false;
        //divtype.Visible = false;
        if (reportDropDownList1.SelectedValue == "IG")
        {
            aInformationReportBll.CreateConnection_DAL();
            CreateGroupGrid(aInformationReportBll.GetItemGroupDatabyId(Parameter()));
            //itemsGridView.DataSource = aInformationReportBll.GetItemGroupDataBll();
            //itemsGridView.DataBind();
            aInformationReportBll.CloseAllConnection();
            //DivGroup.Visible = true;
        }
        if (reportDropDownList1.SelectedValue == "IT")
        {
            aInformationReportBll.CreateConnection_DAL();
            CreateTypeGrid(aInformationReportBll.GetItemTypeDatabyId(Parameter()));
            //itemsGridView.DataSource = aInformationReportBll.GetItemGroupDataBll();
            //itemsGridView.DataBind();
            aInformationReportBll.CloseAllConnection();
        }
        if (reportDropDownList1.SelectedValue == "ICA")
        {
            aInformationReportBll.CreateConnection_DAL();
            CreateCategoryGrid(aInformationReportBll.GetItemCategoryDatabyId(Parameter()));
            //itemsGridView.DataSource = aInformationReportBll.GetItemGroupDataBll();
            //itemsGridView.DataBind();
            aInformationReportBll.CloseAllConnection();
        }
        if (reportDropDownList1.SelectedValue == "IN")
        {
            aInformationReportBll.CreateConnection_DAL();
            CreateNameGrid(aInformationReportBll.GetItemNameDatabyId(Parameter()));
            //itemsGridView.DataSource = aInformationReportBll.GetItemGroupDataBll();
            //itemsGridView.DataBind();
            aInformationReportBll.CloseAllConnection();
        }
        if (reportDropDownList1.SelectedValue == "ID")
        {
            aInformationReportBll.CreateConnection_DAL();
            CreateDescGrid(aInformationReportBll.GetItemDescDatabyId(Parameter()));
            //itemsGridView.DataSource = aInformationReportBll.GetItemGroupDataBll();
            //itemsGridView.DataBind();
            aInformationReportBll.CloseAllConnection();
        }
      
    }
    protected void reportDropDownList1_SelectedIndexChanged(object sender, EventArgs e)
    {
        DivGroup.Visible = false;
        divcat.Visible = false;
        divname.Visible = false;
        divtype.Visible = false;
        divdesc.Visible = false;
        if (reportDropDownList1.SelectedValue == "IG")
        {
            //aInformationReportBll.CreateConnection_DAL();
            //itemsGridView.DataSource = aInformationReportBll.GetItemGroupDataBll();
            //itemsGridView.DataBind();
            //aInformationReportBll.CloseAllConnection();
            DivGroup.Visible = true;
        }
        if (reportDropDownList1.SelectedValue == "IT")
        {
            DivGroup.Visible = true;
            divtype.Visible = true;
        }
        if (reportDropDownList1.SelectedValue == "ICA")
        {
            DivGroup.Visible = true;
            divtype.Visible = true;
            divcat.Visible = true;
        }
        if (reportDropDownList1.SelectedValue == "IN")
        {
            DivGroup.Visible = true;
            divtype.Visible = true;
            divcat.Visible = true;
            divname.Visible = true;
        }
        if (reportDropDownList1.SelectedValue == "IN")
        {
            DivGroup.Visible = true;
            divtype.Visible = true;
            divcat.Visible = true;
            divname.Visible = true;
        }
        if (reportDropDownList1.SelectedValue == "ID")
        {
            DivGroup.Visible = true;
            divtype.Visible = true;
            divcat.Visible = true;
            divname.Visible = true;
            divdesc.Visible = true;
            divdesother.Visible = true;
            divdesother2.Visible = true;

        }
    }

