    public void LoadDropdownList()
    {
        aItemDescriptionBLL.CreateConnection_UA_DB();
        aItemDescriptionBLL.LoadItemGroup(itemGroupDropDownList);
        aItemDescriptionBLL.LoadItemBrand(itembrandDropDownList);
        aItemDescriptionBLL.LoadItemColor(itemcolorDropDownList);
        aItemDescriptionBLL.LoadItemManufacture(itemManufactureDropDownList);
        //aItemDescriptionBLL.LoadItemCountry(countryDropDownList);
        aItemDescriptionBLL.LoadItemSizeMaster(itemSizeMasterDropDownList);
        aItemDescriptionBLL.LoadUomMaster(stockUnitDropDownList);
        //aItemDescriptionBLL.LoadItemBrand(itembrandDropDownList);
        //aItemDescriptionBLL.LoadItemColor(itemcolorDropDownList);
        //aItemDescriptionBLL.LoadItemManufacture(itemManufactureDropDownList);
        //aItemDescriptionBLL.LoadItemCountry(countryDropDownList);
        //aItemDescriptionBLL.LoadItemSizeMaster(itemSizeMasterDropDownList);
        //aItemDescriptionBLL.LoadUomMaster(stockUnitDropDownList);
        //  aItemDescriptionBLL.LoadFA(FADropDownList);
        aItemDescriptionBLL.CloseAllConnection();
    }
