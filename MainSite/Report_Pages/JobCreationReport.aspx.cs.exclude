    public void CreateGridColumn(DataTable aDataTable)
    {
        if (aDataTable.Columns.Count>0)
        {
            itemsGridView.Columns.Clear();
        }
        for (int i = 0; i < aDataTable.Columns.Count; i++)
        {
            BoundField col = new BoundField();
            col.DataField = aDataTable.Columns[i].ColumnName;
            col.HeaderText = aDataTable.Columns[i].ColumnName;
            itemsGridView.Columns.Add(col);
        }
        itemsGridView.DataSource = aDataTable;
        itemsGridView.DataBind();
    }

